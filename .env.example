# ============================================================
# RatingGuard — 跨境电商 AI 差评挽回特工
# 环境变量配置模板
# 使用方式：cp .env.example .env 并填入真实值
# ============================================================

# ---------- Shopify 商店配置 ----------
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_API_VERSION="2024-01"

# ---------- 爬虫行为控制 ----------
SCRAPER_REQUEST_DELAY_MIN=2.0
SCRAPER_REQUEST_DELAY_MAX=5.0
SCRAPER_REQUEST_TIMEOUT=30
# 自定义 UA（留空则使用内置随机池）
SCRAPER_USER_AGENT=""

# ---------- LLM 配置（任选一种或多种） ----------

# OpenAI / GPT-4o
OPENAI_API_KEY="sk-..."
OPENAI_MODEL_NAME="gpt-4o"
OPENAI_BASE_URL="https://api.openai.com/v1"

# DeepSeek
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_MODEL_NAME="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# ---------- 定时任务 ----------
CRON_SCHEDULE="0 9 * * 1-5"
TIMEZONE="Asia/Shanghai"

# ---------- 日志 ----------
LOG_LEVEL="INFO"
LOG_FILE="logs/ratingguard.log"
